{
  "name": "pos-desktop-frontend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Vue 3 single-page application for the POS Desktop App (Option B). Talks to the bundled Laravel API at /api/v1 and to the Electron shell via the preload bridge.",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . --ext .js,.vue",
    "format": "prettier --write \"src/**/*.{js,vue,css,html}\""
  },
  "engines": {
    "node": ">=18.17.0"
  },
  "dependencies": {
    "@headlessui/vue": "1.7.23",
    "@vueuse/core": "11.3.0",
    "axios": "1.7.9",
    "chart.js": "4.4.7",
    "pinia": "2.3.0",
    "tailwindcss": "3.4.17",
    "vue": "3.5.13",
    "vue-chartjs": "5.3.2",
    "vue-router": "4.5.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "5.2.1",
    "@vue/test-utils": "2.4.6",
    "autoprefixer": "10.4.20",
    "eslint": "8.57.1",
    "eslint-config-prettier": "9.1.0",
    "eslint-plugin-vue": "9.32.0",
    "fast-check": "3.23.2",
    "happy-dom": "15.11.7",
    "postcss": "8.4.49",
    "prettier": "3.4.2",
    "vite": "5.4.11",
    "vitest": "2.1.8"
  }
}
